# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
# Local MongoDB (default). Replace with your Atlas URI for staging/prod:
# mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/jenpark?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/jenpark

# -----------------------------------------------------------
# JWT
# -----------------------------------------------------------
# Securely generated 256-bit secrets — NEVER share or commit these
JWT_SECRET=40a9e712c771a480c0f0cf6f4fd1cdd2d23ba34e4197b6676a74d924d272147b
JWT_REFRESH_SECRET=67553f8542798e8d857b714939536ee95f3815c5947afbc4cd4a42ae929bc7c3
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------
# AWS S3 (MinIO @ s3.diginexatechnologies.com)
# -----------------------------------------------------------
AWS_ACCESS_KEY=jenpark-user
AWS_SECRET_KEY=JenPark_Key_2026
AWS_BUCKET=jenpark
AWS_REGION=us-east-1
AWS_ENDPOINT=https://s3.diginexatechnologies.com
AWS_S3_FORCE_PATH_STYLE=true
AWS_CDN_URL=https://s3.diginexatechnologies.com/jenpark

# -----------------------------------------------------------
# S3 / MinIO (Image Storage) — alt naming
# -----------------------------------------------------------
S3_ENDPOINT=https://s3.diginexatechnologies.com
CDN_BASE_URL=https://s3.diginexatechnologies.com
S3_PORT=443
S3_USE_SSL=true
S3_ACCESS_KEY=jenpark-user
S3_SECRET_KEY=JenPark_Key_2026
S3_BUCKET=jenpark
S3_REGION=us-east-1
S3_CDN_URL=https://s3.diginexatechnologies.com/jenpark

# -----------------------------------------------------------
# CORS
# For production set to your frontend origin, e.g. https://app.jenpark.io
# -----------------------------------------------------------
CORS_ORIGIN=*

# -----------------------------------------------------------
# Logging  (error | warn | info | http | verbose | debug | silly)
# -----------------------------------------------------------
LOG_LEVEL=info